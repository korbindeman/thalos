// Apollo-class transfer stage: 4 m Hyperion pod, 4 m × 4 m methalox tank,
// Boreas vacuum engine. Catalog-referenced — all stats live in
// `assets/parts.ron`. This file stores the display name plus per-instance
// parametric data (tank dimensions) and resource amounts; resource entries
// are omitted so each pool spawns full at its catalog-derived capacity.

(
    name: "Apollo",
    root: 0,
    parts: [
        (catalog_id: "hyperion"),
        (
            catalog_id: "tank_methalox",
            params: Tank(diameter: 4.0, length: 4.0),
        ),
        (catalog_id: "boreas"),
    ],
    connections: [
        (parent: 0, parent_node: "bottom", child: 1, child_node: "top"),
        (parent: 1, parent_node: "bottom", child: 2, child_node: "top"),
    ],
)
