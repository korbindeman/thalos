#![enable(implicit_some)]
// Pyros system definition.
//
// Format: see crates/physics/src/parsing.rs (`SolarSystemFile`).
// Distances in meters, angles in degrees, time in seconds, mass in kg.
// Hex colors are sRGB. Every field on every body is explicit — no defaults.
//
// `generator` block is the surface generator pipeline for authored solid
// bodies. Bodies without one render from their physical colour/atmosphere
// until they get bespoke terrain work.

(
    name: "Pyros System",
    epoch: "J2000.0",
    homeworld: "Thalos",
    bodies: [
        // ─────────────────────────────────────────────
        // STAR
        // ─────────────────────────────────────────────
        (
            name: "Pyros",
            kind: Star,
            parent: None,
            physical: (
                mass_kg: 1.989e30,
                radius_m: 696000000.0,
                color: "#FFE54D",
                albedo: 1.0,
                rotation_period_s: 2192832.0,
                axial_tilt_deg: 0.0,
            ),
            orbit: None,
            generator: None,
        ),

        // ─────────────────────────────────────────────
        // INNER SYSTEM
        // ─────────────────────────────────────────────
        (
            name: "Ashara",
            kind: Planet,
            parent: Some("Pyros"),
            physical: (
                mass_kg: 2.628e24,
                radius_m: 4035000.0,
                color: "#D1C774",
                albedo: 0.65,
                rotation_period_s: -15552000.0,
                axial_tilt_deg: 177.0,
            ),
            orbit: Some((
                semi_major_axis_m: 9.724e10,
                eccentricity: 0.01,
                inclination_deg: 2.8,
                lon_ascending_node_deg: 0.0,
                arg_periapsis_deg: 0.0,
                true_anomaly_deg: 192.0,
            )),
            generator: None,
        ),
        (
            name: "Thalos",
            kind: Planet,
            parent: Some("Pyros"),
            physical: (
                mass_kg: 1.378e24,
                radius_m: 3186000.0,
                color: "#3373E5",
                albedo: 0.35,
                rotation_period_s: 76680.0,
                axial_tilt_deg: 23.0,
            ),
            orbit: Some((
                semi_major_axis_m: 1.496e11,
                eccentricity: 0.017,
                inclination_deg: 0.0,
                lon_ascending_node_deg: 0.0,
                arg_periapsis_deg: 0.0,
                true_anomaly_deg: 0.0,
            )),
            // Thalos terrain pipeline (in rebuild).
            //
            // Target spec: `docs/thalos_terrain_pipeline.md`. Six stages,
            // icosphere-canonical, cubemap is a derived render output.
            //
            // Status: Stage 1 (TectonicSkeleton) only. Old stages cleared
            // pending the full rebuild.
            generator: Some((
                seed: 1003,
                // Iron-core Earth analog: ~70% iron by volume, thin silicate
                // crust, residual volatiles as N₂/O₂ atmosphere + hydrosphere.
                // Matches `docs/lore/solar_system.md` composition.
                composition: (silicate: 0.26, iron: 0.70, ice: 0.0, volatiles: 0.04, hydrogen_helium: 0.0),
                cubemap_resolution: 2048,
                body_age_gyr: 4.5,
                pipeline: [
                    // Stage 1 — Tectonic Skeleton. Typed province map that
                    // every subsequent stage cascades from. Low-resolution
                    // icosphere (level 6 ≈ 40 k verts, ~55 km cells on
                    // Thalos). Debug albedo paint is on while Stage 2+
                    // don't exist yet.
                    TectonicSkeleton((
                        // Level 8 icosphere → ~655 k vertices, ~14 km
                        // per hop on Thalos. Resolution where mesh
                        // topology stops visibly leaking into rivers
                        // and coastlines.
                        subdivision_level: 8,
                        // 20 cratons → each ~500 km radius, matching
                        // Archean craton scale.
                        n_cratons: 20,
                        // Noise-warped Voronoi: domain-warps each
                        // vertex before plate assignment, so plate
                        // boundaries become fractal at the warp's
                        // spatial frequency. Continents are decided
                        // *independently* by Stage 2's noise mask —
                        // plates here only drive tectonic features
                        // (sutures / rifts / active margins /
                        // hotspots), which can land on continent or
                        // ocean without aligning to coastlines.
                        plate_warp_amplitude: 0.4,
                        plate_warp_frequency: 3.0,
                        plate_warp_octaves: 5,
                        n_active_margins: 1,
                        n_rift_scars: 2,
                        n_hotspot_tracks: 4,
                        // 12 hops ≈ 170 km on level 8 — Hawaii-scale,
                        // not a 560 km ridge. Only the youngest few
                        // vertices read above water after Stage 2/3
                        // process the track.
                        hotspot_track_length: 12,
                        lloyd_iterations: 3,
                        // Stage 2 paints its own elevation-relief debug
                        // albedo. Turning Stage 1's off keeps the final
                        // bake showing the elevation field, not the flat
                        // province skeleton.
                        debug_paint_albedo: false,
                    )),
                    // Stage 2 — Coarse Elevation. Continental mask
                    // comes from warped fBm noise thresholded to the
                    // target ocean fraction — *independent of the
                    // plate partition*. Plate boundaries drive
                    // tectonic features (sutures, rifts, active
                    // margins, hotspots) that land on continent or
                    // ocean without aligning to coastlines. Matches
                    // Earth: Pacific plate has no continent; Eurasia
                    // carries Europe + Asia; Mid-Atlantic Ridge runs
                    // underwater.
                    CoarseElevation((
                        // Continent mask — warped fBm, thresholded to
                        // hit 65 % ocean by percentile, then
                        // connected-component-filtered to remove
                        // tiny land/ocean fragments.
                        target_ocean_fraction: 0.65,
                        // 6 octaves × 0.55 persistence × freq 2.0 is
                        // the standard fBm "continent profile" — gives
                        // a handful of continent-scale features plus
                        // rich fractal coastline detail at the scales
                        // the mask is designed to show. Fragmentation
                        // from marginal threshold-crossings is cleaned
                        // up after the fact by the component filter.
                        continent_noise_frequency: 2.0,
                        continent_noise_octaves: 6,
                        continent_noise_persistence: 0.55,
                        continent_warp_amplitude: 0.45,
                        continent_warp_frequency: 2.2,
                        // Anisotropic stretch: compress the N-S axis
                        // before noise sampling so features read
                        // wider E-W. 1.5 is Earth-ish (Eurasia-wide
                        // but not striped); >2 starts looking
                        // banded.
                        horizontal_stretch: 1.5,
                        // Quadratic latitude bias `bias·(0.5 - sin²lat)`
                        // added to the mask. Positive pulls land
                        // toward mid/low latitudes. 0.2 is gentle
                        // enough not to carve a hard belt.
                        mid_latitude_bias: 0.2,
                        // Drop land components smaller than 0.3 % of
                        // the sphere (~Madagascar scale) — kills
                        // noise-fragment islands while preserving
                        // real island arcs. Ocean fill disabled:
                        // interior seas are realistic and filling
                        // them drops sea level to hold the 65 %
                        // target, which drowns continental interior.
                        min_land_fraction: 0.003,
                        min_ocean_fraction: 0.0,
                        // Earth-relative baseline elevations:
                        // +500 m continent / -3500 m ocean floor.
                        // Gives a 4 km bias gap; with noise at
                        // 1500 m (half-gap − 500 m buffer) the
                        // distributions stay separate, no coastline
                        // speckle. After erosion, sea level settles
                        // ~−1500 m and continents sit ≈500–3500 m
                        // above sea level — matches Earth's
                        // hypsometric profile.
                        continental_bias_m: 500.0,
                        oceanic_bias_m: -3500.0,
                        // Suture: ~85 km mountain-belt half-width
                        // (Himalayas / Urals scale). Previous values
                        // were 4× too wide, causing 3σ uplift discs
                        // to blanket ~70 % of the planet and push
                        // sea level into collapse.
                        suture_height_m: 1500.0,
                        suture_falloff_hops: 6.0,
                        suture_age_decay_myr: 800.0,
                        rift_depth_m: 800.0,
                        rift_falloff_hops: 3.0,
                        // Active margin: Andes-scale arc + offshore
                        // trench. 4 hops ≈ 56 km (narrower than
                        // Andes' 100 km but matches sharp-relief
                        // spec). Trench peak 10 hops offshore ≈ 140
                        // km.
                        active_uplift_m: 3500.0,
                        active_trench_m: 3500.0,
                        active_falloff_hops: 4.0,
                        trench_offset_hops: 10.0,
                        trench_width_hops: 3.0,
                        // Seamounts as point-like bumps (1.5-hop tight
                        // Gaussian) rather than a continuous ridge.
                        // Paired with shorter track length below,
                        // renders as Hawaii-style isolated island
                        // chain (just a couple above water) rather
                        // than a visible linear ridge in the ocean.
                        hotspot_height_m: 800.0,
                        hotspot_falloff_hops: 1.5,
                        // 1500 m noise, inside the 2000 m half-gap
                        // with 500 m buffer. Gives visible
                        // elevation variation inside continents and
                        // oceans without letting ocean noise push
                        // above sea level as speckle islands.
                        noise_amplitude_m: 1500.0,
                        noise_frequency: 2.5,
                        noise_octaves: 7,
                        noise_persistence: 0.62,
                        // Doubled warp amplitude (0.30 vs 0.15) — domain
                        // warp displaces each sample point by ~30% of
                        // the unit-sphere radius in each axis before
                        // fbm is evaluated. That's enough distortion
                        // that the noise structure bends the
                        // continentalness-derived coastline into
                        // peninsulas, bays, and detached island arcs
                        // instead of gently-lumpy blobs.
                        // Strong domain warp: displaces sample position
                        // by ~45 % of the unit sphere radius before fbm
                        // evaluation. Enough distortion that the
                        // continentalness-derived coastline bends into
                        // complex peninsulas and detached fragments,
                        // burying the underlying craton Voronoi shape.
                        warp_amplitude: 0.45,
                        warp_frequency: 3.0,
                        // Stage 3 repaints the albedo on top of this;
                        // we still want Stage 2's bake in place in case
                        // Stage 3 is truncated via `--up-to-stage`.
                        debug_paint_albedo: true,
                    )),
                    // Stage 3 — Hydrological Carving. The character-
                    // defining stage: water carves the Stage 2
                    // heightfield into dendritic valleys, sediment
                    // fills lowlands, and sea level is set last to hit
                    // the 65% ocean target. Drainage graph and sediment
                    // map persist to BodyData for later stages and
                    // gameplay.
                    HydrologicalCarving((
                        // 100 iterations of stream-power erosion —
                        // enough to carve visible valleys into all but
                        // the flattest lowlands without pounding the
                        // continents into flatness.
                        erosion_iterations: 100,
                        erosion_k: 2.0e-4,
                        stream_power_m: 0.5,
                        stream_power_n: 1.0,
                        max_erosion_per_iter_m: 50.0,
                        deposition_rate: 0.08,
                        pit_fill_epsilon_m: 0.001,
                        // Spec: Thalos is 65% ocean.
                        target_ocean_fraction: 0.65,
                        // Only show trunk rivers — at level 8 every
                        // headwater is resolved, but capillaries are
                        // sub-pixel at orbital view.
                        river_accumulation_threshold_m2: 2.0e11,
                        // ~2.5 km half-width — visible as thin lines
                        // from orbital view without dominating. Real
                        // equivalent: Amazon / Mississippi reading
                        // from ISS altitude.
                        river_half_width_rad: 0.0008,
                        // Stage 5 paints the material map over the top;
                        // leaving Stage 3's hypsometric paint off so the
                        // final bake shows the material assignments.
                        debug_paint_albedo: false,
                    )),
                    // Stage 5 — Surface Materials. Assigns a material
                    // ID to every vertex based on history: province
                    // kind + age, drainage accumulation, sediment
                    // thickness, and upstream iron provenance. The
                    // "Thalos is rust" read comes from Stage 3's
                    // drainage routing iron-rich sediment (eroded
                    // arc volcanics from ActiveMargin + HotspotTrack
                    // provinces) to lowland floodplains and beaches.
                    SurfaceMaterials((
                        // Narrow coastal band: 200 m below sea level.
                        // Stage 3's continental-shelf deposition
                        // elevates the inner seabed fast, so a wider
                        // band fills nearly half the ocean. 200 m
                        // keeps the shelf reading as a visible ring
                        // along coasts rather than overtaking the
                        // abyssal plains.
                        shelf_depth_m: 200.0,
                        // log10(5·10⁹ m²) ≈ 9.7 — catches mid-sized
                        // rivers, not just continental-trunk mains.
                        // At level 8 (~655 k verts, ~2·10⁸ m² per
                        // cell) this is a catchment of ~25 cells,
                        // about where dendritic tributaries start
                        // showing visible accumulation in Stage 3.
                        floodplain_log10_accumulation_m2: 9.7,
                        // 0.5 m sediment — Stage 3's sediment is
                        // heavily skewed (median 0, 90th pct ~1 m,
                        // peak ~2 km). 0.5 m captures "visible
                        // deposition" without requiring the vertex
                        // to be a sink.
                        floodplain_min_sediment_m: 0.5,
                        // Below 1500 m above sea level: lowland /
                        // foothill reading. Floodplains up to this
                        // height cover a broad belt of continental
                        // interior at Thalos's post-erosion profile.
                        floodplain_max_elevation_m: 1500.0,
                        // Above 2500 m with <0.3 m sediment = scoured
                        // upland. Rare at Thalos's mature profile;
                        // only the peaks in Suture belts and the
                        // live ActiveMargin arc qualify.
                        bare_rock_min_elevation_m: 2500.0,
                        bare_rock_max_sediment_m: 0.3,
                        // Stable terrain can carry up to 5 m of
                        // weathered blanket and still read as
                        // "Craton at surface." Above that it's
                        // regolith — transported-sediment drape,
                        // not in-place weathering. Combined with
                        // the sediment distribution this keeps
                        // most craton interiors in granite/BIF
                        // rather than generic regolith.
                        ancient_stable_max_sediment_m: 5.0,
                        // ActiveMargin + HotspotTrack vertices with
                        // age ≤ 30 Myr still carry fresh basalt
                        // signatures. Older than that and even
                        // the rare live provinces read as
                        // weathered volcanic soils in the
                        // downstream-rule pass.
                        fresh_volcanic_max_age_myr: 30.0,
                        // Source weights. Active arcs are the
                        // strongest iron emitters per unit area,
                        // hotspots the most concentrated, Suture
                        // belts weakest. Suture is a fallback
                        // stand-in for ArcRemnant (which
                        // TectonicSkeleton doesn't emit yet); keep
                        // it below the "active" tier so 51 sutures
                        // don't swamp the drainage network.
                        iron_source_active_margin: 1.0,
                        iron_source_hotspot_track: 1.0,
                        iron_source_suture: 0.15,
                        // Floodplain iron cutoff ≈ 5 % catchment-
                        // averaged iron source. Previous 1 %
                        // painted rust on every trunk river; 10 %
                        // eliminated it almost entirely (61 texels).
                        // 5 % catches floodplains that are genuinely
                        // downstream of an iron source — active
                        // margins clear it easily, suture-dominated
                        // catchments clear it if the upstream is
                        // >33 % suture.
                        iron_fraction_threshold: 0.05,
                        // BIF: an old Suture is iron-bearing even
                        // without supercatchment downstream —
                        // being part of the belt itself counts.
                        // Pair with the suture source weight so a
                        // suture vertex in a suture-dominated
                        // catchment clears it.
                        iron_fraction_bif_threshold: 0.04,
                        // PaintBiomes paints the final albedo using
                        // the climate-driven biome palette. Material
                        // IDs from this stage still drive per-texel
                        // roughness; we just don't bake their flat
                        // colours.
                        debug_paint_albedo: false,
                    )),
                    // Stage 6 — Climate. Earth-like annual-mean
                    // temperature + precipitation derived from
                    // latitude, altitude, and upwind-traced
                    // continentality / orographic effects. Tuned to
                    // Thalos's slightly-thinner atmosphere and smaller
                    // radius: equator a touch cooler than Earth, polar
                    // gradient a touch sharper. Drives the Whittaker-
                    // style biome rules below.
                    Climate((
                        equator_temp_c: 28.0,
                        polar_temp_c: -15.0,
                        // 1.6 keeps mid-latitudes temperate and pushes
                        // the cold drop into the polar circle —
                        // without it the gradient runs through 0 °C
                        // at ~50° latitude and tundra eats the
                        // continents.
                        lat_exponent: 1.6,
                        lapse_c_per_km: 6.5,
                        // Earth-like zonal precipitation profile with
                        // a sharper subtropical-high desert band
                        // (10–30° latitude). Bands: ITCZ → subtropical
                        // highs → mid-latitude westerlies → polar
                        // deserts.
                        zonal_precip_mm: (2400.0, 1800.0, 350.0, 600.0, 1200.0, 1100.0, 800.0, 400.0, 200.0),
                        // 12 steps × 0.025 rad ≈ 0.3 rad ≈ 950 km
                        // trace. At Thalos's 1:2 scale (radius 3186
                        // km), continents are smaller than Earth's, so
                        // a wider step (0.05 rad ≈ 160 km/step on a
                        // 1:1 body, but only 80 km/step here in
                        // surface terms) ran the upwind ray off
                        // continents in 2-3 steps and continentality
                        // never bit. A finer step keeps the trace
                        // inside continental interiors long enough to
                        // dry them out.
                        upwind_steps: 12,
                        step_arc_rad: 0.025,
                        // Aggressive decay: 0.85^12 ≈ 0.14, so the
                        // deepest continental interior receives only
                        // ~14 % of the zonal moisture even before
                        // mountain shadowing. With 0.90 the same
                        // figure was 0.28 — twice as wet, so deserts
                        // never formed away from subtropical bands.
                        continentality_decay: 0.85,
                        orographic_gain_per_km: 0.5,
                        rain_shadow_per_km: 0.4,
                        // 0.30 fbm jitter (was 0.15) — breaks the
                        // visible east-west banding that arises when
                        // precipitation tracks the zonal profile too
                        // cleanly.
                        precip_noise_amp: 0.30,
                        precip_noise_frequency: 3.0,
                    )),
                    // Stage 7 — Biomes. Whittaker-style climate
                    // partition. Order matters (first-match-wins) so
                    // tundra / taiga / desert eat their corners of
                    // the (T, P) plane before temperate / grassland
                    // catch the broad middle. Per-biome
                    // `iron_visibility` controls how much the
                    // PaintBiomes IronOverlay shows through: closed-
                    // canopy biomes hide rust, exposed-ground biomes
                    // show it.
                    Biomes((
                        biomes: [
                            // 0 — tundra. High latitude, treeless
                            // mineral soil and lichen. Iron-rich
                            // catchments stain visibly through the
                            // sparse cover.
                            (name: "tundra", albedo: 0.34, tint: (1.00, 1.05, 0.95), tonal_amp: 0.20, roughness: 0.78, iron_visibility: 0.65),
                            // 1 — taiga (boreal forest). Dark conifer
                            // canopy hides almost all substrate.
                            (name: "taiga", albedo: 0.15, tint: (0.78, 1.06, 0.62), tonal_amp: 0.22, roughness: 0.72, iron_visibility: 0.10),
                            // 2 — cold steppe / cold desert. Sparse
                            // grass over mineral soil; iron shows
                            // through.
                            (name: "cold_steppe", albedo: 0.32, tint: (1.05, 1.00, 0.78), tonal_amp: 0.22, roughness: 0.78, iron_visibility: 0.60),
                            // 3 — hot desert. Bare regolith, fully
                            // exposed; rust paints through at full
                            // strength on iron-rich catchments.
                            (name: "hot_desert", albedo: 0.42, tint: (1.18, 1.00, 0.62), tonal_amp: 0.18, roughness: 0.82, iron_visibility: 1.00),
                            // 4 — tropical rainforest. Saturated
                            // green; deep canopy hides everything
                            // below.
                            (name: "tropical_rainforest", albedo: 0.18, tint: (0.62, 1.10, 0.42), tonal_amp: 0.16, roughness: 0.65, iron_visibility: 0.05),
                            // 5 — tropical savanna / dry forest. Tan-
                            // green mosaic with seasonal grass cover;
                            // moderate iron exposure.
                            (name: "tropical_savanna", albedo: 0.30, tint: (1.10, 1.05, 0.55), tonal_amp: 0.22, roughness: 0.75, iron_visibility: 0.55),
                            // 6 — temperate forest. Mid-green deciduous
                            // / mixed canopy. Mostly closed.
                            (name: "temperate_forest", albedo: 0.20, tint: (0.78, 1.05, 0.55), tonal_amp: 0.20, roughness: 0.70, iron_visibility: 0.15),
                            // 7 — grassland / prairie. Yellow-green
                            // continuous grass; partial soil exposure.
                            (name: "grassland", albedo: 0.28, tint: (1.02, 1.10, 0.60), tonal_amp: 0.22, roughness: 0.75, iron_visibility: 0.50),
                            // 8 — semiarid steppe. Default catch-all:
                            // pale dry sparse vegetation, mineral soil
                            // visible.
                            (name: "semiarid_steppe", albedo: 0.36, tint: (1.10, 1.00, 0.72), tonal_amp: 0.20, roughness: 0.78, iron_visibility: 0.80),
                        ],
                        rules: [
                            TempPrecip(max_temp_c: -3.0, jitter_amp: 0.22, jitter_frequency: 3.0),
                            TempPrecip(max_temp_c: 5.0, min_precip_mm: 350.0, jitter_amp: 0.22, jitter_frequency: 3.0),
                            TempPrecip(max_temp_c: 5.0, jitter_amp: 0.22, jitter_frequency: 3.0),
                            TempPrecip(min_temp_c: 15.0, max_precip_mm: 400.0, jitter_amp: 0.12, jitter_frequency: 3.5),
                            TempPrecip(min_temp_c: 22.0, min_precip_mm: 1800.0, jitter_amp: 0.22, jitter_frequency: 3.0),
                            TempPrecip(min_temp_c: 20.0, jitter_amp: 0.22, jitter_frequency: 3.0),
                            TempPrecip(min_precip_mm: 700.0, jitter_amp: 0.22, jitter_frequency: 3.0),
                            TempPrecip(min_precip_mm: 250.0, jitter_amp: 0.22, jitter_frequency: 3.0),
                            Default,
                        ],
                    )),
                    // Stage 8 — PaintBiomes. Continuous overlays on
                    // top of the biome base palette: iron staining
                    // (downstream of mafic provinces, gated by per-
                    // biome ground exposure), bare-rock outcrops
                    // (steep slopes, high altitude), snow/ice cover
                    // (temperature-driven), slope-AO darkening.
                    PaintBiomes((
                        // Iron oxide rust paints through exposed-ground
                        // biomes (deserts, tundra, steppe) where the
                        // upstream catchment routed mafic-derived
                        // sediment to the cell. min/max bracket the
                        // SurfaceMaterials threshold (0.05) so staining
                        // ramps up across the same iron_fraction range
                        // the classifier flags as iron-rich.
                        iron_overlay: (
                            // After SurfaceMaterials' dilation+blur,
                            // peaks of the iron_fraction field stay
                            // close to their original (0.05–0.5)
                            // range — dilation preserves max values
                            // and only the soft fade-out band drops.
                            // Threshold sits just above the
                            // classifier cutoff (0.05) so the same
                            // catchments the classifier flags get
                            // visible staining.
                            min_iron_fraction: 0.04,
                            max_iron_fraction: 0.22,
                            // Cap at 0.55 strength so iron-rich
                            // regions read as warm reddish biome,
                            // not pure rust paint. Biome character
                            // (sand colour, grass tint) bleeds
                            // through at full saturation.
                            max_strength: 0.55,
                            // Warm earth-rust, less saturated than
                            // the previous Mars-orange — reads as
                            // iron-stained soil rather than safety-
                            // cone paint.
                            color: (0.50, 0.32, 0.22),
                            tonal_amp: 0.22,
                            tonal_frequency: 9.0,
                        ),
                        // Bare rock above 3 km or on steep slopes.
                        // Cool gray basalt / weathered granite — sits
                        // visibly cooler than the surrounding biomes
                        // so peaks read as snow-shoulders even before
                        // snow_overlay paints them white.
                        rock_overlay: (
                            slope_start: 0.20,
                            slope_full: 0.55,
                            height_boost_from_m: 3000.0,
                            height_boost_per_km: 0.30,
                            color: (0.52, 0.50, 0.50),
                            tonal_amp: 0.12,
                            tonal_frequency: 14.0,
                        ),
                        // Snow/ice on land. Coverage by temperature
                        // (jittered) so equatorial peaks can carry
                        // glaciers and warm polar land can stay bare.
                        // Sea ice is a shader-side concern.
                        snow_overlay: (
                            // Coverage ramp: starts at 0 °C, full at
                            // -12 °C. Earlier values (full at -8 °C)
                            // turned every continent's mid-latitude
                            // interior into a polar cap. With the
                            // current Climate config, this leaves
                            // snow concentrated above ~50° latitude
                            // and on alpine peaks.
                            temp_none_c: 0.0,
                            temp_full_c: -12.0,
                            jitter_amp_c: 4.0,
                            jitter_frequency: 3.0,
                            land_color: (0.92, 0.93, 0.96),
                            tonal_amp: 0.04,
                        ),
                        // Slope-AO darkens steep terrain so mountain
                        // relief reads from orbit even when the sun
                        // angle hides detailed normals.
                        slope_ao: (
                            slope_start: 0.18,
                            slope_full: 0.55,
                            max_darken: 0.30,
                        ),
                    )),
                ],
            )),
            // Thin N₂/O₂ atmosphere (~0.85 atm). Rim halo + limb
            // shading compose the "blue halo + chromatic limb" read
            // that distinguishes a living planet from an airless
            // twin at impostor distance. Clouds/storms are a
            // separate layer (see docs/gen/thalos_processes.md
            // §Atmosphere/Clouds).
            terrestrial_atmosphere: Some((
                // Pale blue rim glow. Scale height tuned to Earth's
                // ~8.4 km × 0.85 atm ≈ 7 km at 1 AU insolation;
                // outer shell cuts off around 80 km, above which
                // column density is negligible.
