        (
            name: "Nyx",
            kind: Moon,
            parent: Some("Erebos"),
            physical: (
                mass_kg: 5.2e19,
                radius_m: 240000.0,
                color: "#996659",
                albedo: 0.10,
                rotation_period_s: 552960.0,
                axial_tilt_deg: 0.0,
            ),
            orbit: Some((
                semi_major_axis_m: 1.9448e7,
                eccentricity: 0.0,
                inclination_deg: 0.0,
                lon_ascending_node_deg: 0.0,
                arg_periapsis_deg: 0.0,
                true_anomaly_deg: 0.0,
            )),
            generator: Some((
                seed: 1400,
                composition: (silicate: 0.38, iron: 0.0, ice: 0.60, volatiles: 0.02, hydrogen_helium: 0.0),
                cubemap_resolution: 1024,
                body_age_gyr: 4.6,
                pipeline: [
                    Differentiate(()),
                    // Dirty-ice moon of Erebos — tidally locked close-in
                    // satellite. +Z = near-side. Large ancient impact on
                    // the leading hemisphere plus scattered smaller basins.
                    // Ice is much weaker than silicate, so basins are
                    // shallower (depth/radius ratio) and relax over time.
                    Megabasin((
                        basins: [
                            // 0: leading-hemisphere primary.
                            (center_dir: ( 0.85,  0.10,  0.52), radius_m: 130000.0, depth_m: 3200.0, ring_count: 3),
                            // 1: far-side older basin.
                            (center_dir: (-0.40,  0.35, -0.85), radius_m: 80000.0, depth_m: 2000.0, ring_count: 2),
                            // 2: degraded near-polar basin.
                            (center_dir: ( 0.05,  0.88,  0.47), radius_m: 55000.0, depth_m: 1400.0, ring_count: 2),
                            // 3-4: small overprinted scars.
                            (center_dir: (-0.62, -0.55,  0.56), radius_m: 38000.0, depth_m: 900.0, ring_count: 1),
                            (center_dir: ( 0.30, -0.80, -0.52), radius_m: 30000.0, depth_m: 700.0, ring_count: 1),
                        ],
                        hemispheric_lowering_m: 0.0,
                    )),
                    // Dirty-ice surface: three units reflecting how airless
                    // icy regoliths actually look:
                    //   - clean exposed ice (fresh tectonic ridges, bright),
                    //   - dirty regolith (silicate dust lag over old ice),
                    //   - cryo mantle (darker, volatile-rich patches).
                    // Fbm rules give fractal boundaries instead of discs.
                    Biomes((
                        biomes: [
                            // 0: clean water ice — exposed ridges, fracture
                            // scarps, bright cool-white with a faint blue cast.
                            (
                                name: "clean_ice",
                                albedo: 0.62,
                                fresh_albedo: Some(0.88),
                                tint: (0.97, 1.00, 1.05),
                                tonal_amp: 0.18,
                                roughness: 0.55,
                            ),
                            // 1: cryo mantle — darker volatile-rich unit,
                            // slightly reddish from organics/tholins.
                            (
                                name: "cryo_mantle",
                                albedo: 0.28,
                                fresh_albedo: Some(0.48),
                                tint: (1.06, 1.00, 0.93),
                                tonal_amp: 0.26,
                                roughness: 0.70,
                            ),
                            // 2: dirty regolith — default catch-all, silicate
                            // dust lag over old ice.
                            (
                                name: "dirty_ice",
                                albedo: 0.42,
                                fresh_albedo: Some(0.66),
                                tint: (1.01, 1.00, 0.98),
                                tonal_amp: 0.22,
                                roughness: 0.62,
                            ),
                        ],
                        rules: [
                            Fbm(frequency: 3.2, threshold: 0.24, octaves: 4),
                            Fbm(frequency: 2.0, threshold: 0.20, octaves: 4),
                            Default,
                        ],
                    )),
                    Cratering((
                        total_count: 89000,
                        sfd_slope: 2.0,
                        sfd_slope_small: None,
                        sfd_break_radius_m: None,
                        min_radius_m: 750.0,
                        max_radius_m: 22000.0,
                        age_bias: 1.0,
                        cubemap_bake_threshold_m: 750.0,
                        secondary_parent_radius_m: 0.0,
                        secondaries_per_parent: 0,
                    )),
                    // Cryovolcanic flood plains — Nyx sits deep in Erebos's
                    // gravity well so tidal heating briefly melted near-
                    // surface ice, flooding low regions with cryolava
                    // (brine slush) that refroze into smooth plains. Much
                    // darker than surrounding clean/dirty ice; wrinkle
                    // ridges on for Europa/Ganymede-adjacent character.
                    MareFlood((
                        target_count: 0,
                        additional_crater_count: 10,
                        fill_fraction: 0.55,
                        near_side_bias: 0.35,
                        boundary_noise_amplitude_m: 450.0,
                        boundary_noise_freq: 12.0,
                        episode_count: 2,
                        wrinkle_ridges: true,
                    )),
                    // Thermal-contraction scarps from the ice shell cooling
                    // and freezing inward after the tidal heating episode.
                    // Lower and shorter than Mercury's — ice can't sustain
                    // the same elastic stress.
                    Scarps((
                        count: 16,
                        min_length_m: 30000.0,
                        max_length_m: 90000.0,
                        width_m: 2500.0,
                        height_m: 180.0,
                        curvature: 0.08,
                    )),
                    Regolith((
                        amplitude_m: 4.5,
                        characteristic_wavelength_m: 85.0,
                        crater_density_multiplier: 1.0,
                        bake_d_min_m: 300.0,
                        bake_scale: 1.0,
                        density_modulation: 0.25,
                        density_wavelength_m: 70000.0,
                    )),
                    SpaceWeather((
                        // Biomes drive highland color — no grayscale override.
                        mare_mature_albedo: 0.24,
                        mare_fresh_albedo: 0.42,
                        // Cryolava plains weather slightly warm/brown from
                        // organics concentrated at the refreezing front.
                        mare_tint: (1.08, 1.00, 0.88),
                        young_crater_age_threshold: 0.85,
                        ray_age_threshold: 0.30,
                        ray_extent_radii: 10.0,
                        ray_count_per_crater: 14,
                        ray_half_width: 0.055,
                    )),
                ],
            )),
        ),
