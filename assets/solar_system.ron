                                min_temp_c: 5.0,
                                max_temp_c: 22.0,
                                min_precip_mm: 700.0,
                                jitter_amp: 0.18,
                            ),
                            // Any remaining dry cell → cold desert.
                            TempPrecip(
                                max_precip_mm: 250.0,
                                jitter_amp: 0.18,
                            ),
                            // Cool (−5..5 °C) with moisture → taiga.
                            TempPrecip(
                                min_temp_c: -5.0,
                                max_temp_c: 5.0,
                                jitter_amp: 0.18,
                            ),
                            // Very cold → tundra (snow overlay blends on top).
                            TempPrecip(
                                max_temp_c: -5.0,
                                jitter_amp: 0.18,
