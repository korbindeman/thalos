#![enable(implicit_some)]
// Pyros system definition.
//
// Format: see crates/physics/src/parsing.rs (`SolarSystemFile`).
// Distances in meters, angles in degrees, time in seconds, mass in kg.
// Hex colors are sRGB. Every field on every body is explicit — no defaults.
//
// `generator` block is the surface generator pipeline. Currently only Mira
// has one. Other bodies will get their own pipelines as the surface
// generator grows to cover them.

(
    name: "Pyros System",
    epoch: "J2000.0",
    homeworld: "Thalos",
    bodies: [
        // ─────────────────────────────────────────────
        // STAR
        // ─────────────────────────────────────────────
        (
            name: "Pyros",
            kind: Star,
            parent: None,
            physical: (
                mass_kg: 1.989e30,
                radius_m: 696000000.0,
                color: "#FFE54D",
                albedo: 1.0,
                rotation_period_s: 2192832.0,
                axial_tilt_deg: 0.0,
            ),
            orbit: None,
            generator: None,
        ),

        // ─────────────────────────────────────────────
        // INNER SYSTEM
        // ─────────────────────────────────────────────
        (
            name: "Ignis",
            kind: Planet,
            parent: Some("Pyros"),
            physical: (
                mass_kg: 1.55e22,
                radius_m: 813000.0,
                color: "#D9591A",
                albedo: 0.12,
                rotation_period_s: 5184000.0,
                axial_tilt_deg: 0.0,
            ),
            orbit: Some((
                semi_major_axis_m: 4.488e10,
                eccentricity: 0.02,
                inclination_deg: 5.8,
                lon_ascending_node_deg: 0.0,
                arg_periapsis_deg: 0.0,
                true_anomaly_deg: 47.0,
            )),
            generator: Some((
                seed: 1100,
                composition: (silicate: 0.28, iron: 0.70, ice: 0.0, volatiles: 0.02, hydrogen_helium: 0.0),
                cubemap_resolution: 2048,
                body_age_gyr: 4.6,
                pipeline: [
                    Differentiate(()),
                    // Iron-rich Mercurian analog. Caloris-class giant basin
                    // plus a scatter of older degraded basins. Slow rotator
                    // with no strong tidal lock here, so basin placement is
                    // random (no far-side bias like Mira).
                    Megabasin((
                        basins: [
                            // 0: Caloris-class primary — dominant multi-ring
                            // structure, ~47% of body radius.
                            (center_dir: ( 0.55,  0.10,  0.83), radius_m: 380000.0, depth_m: 5200.0, ring_count: 4),
                            // 1: older large basin, partially overprinted.
                            (center_dir: (-0.70, -0.30, -0.65), radius_m: 240000.0, depth_m: 3800.0, ring_count: 3),
                            // 2-5: degraded paleo-basins.
                            (center_dir: ( 0.10,  0.78, -0.62), radius_m: 180000.0, depth_m: 2800.0, ring_count: 2),
                            (center_dir: (-0.45,  0.55,  0.70), radius_m: 150000.0, depth_m: 2300.0, ring_count: 2),
                            (center_dir: ( 0.30, -0.72,  0.62), radius_m: 120000.0, depth_m: 1800.0, ring_count: 1),
                            (center_dir: (-0.85,  0.20,  0.49), radius_m: 100000.0, depth_m: 1500.0, ring_count: 1),
                        ],
                        hemispheric_lowering_m: 0.0,
                    )),
                    // Three-biome split modeled after Mercury:
                    //   - heavily cratered iron-rich crust (dark, default),
                    //   - intercrater plains (intermediate brightness, the
                    //     volumetrically dominant Mercurian unit),
                    //   - smooth plains (brighter volcanic infill around the
                    //     Caloris-class basin and other low regions).
                    // Rules are fbm fields so boundaries are fractal, not
                    // disc cut-outs.
                    Biomes((
                        biomes: [
                            // 0: smooth volcanic plains — brighter, slightly
                            // warmer feldspathic/silicate veneer over iron.
                            (
                                name: "smooth_plains",
                                albedo: 0.085,
                                fresh_albedo: Some(0.17),
                                tint: (1.05, 1.00, 0.94),
                                tonal_amp: 0.22,
                                roughness: 0.72,
                            ),
                            // 1: intercrater plains — intermediate, the
                            // default Mercurian surface unit.
                            (
                                name: "intercrater_plains",
                                albedo: 0.075,
                                fresh_albedo: Some(0.14),
                                tint: (1.02, 1.00, 0.97),
                                tonal_amp: 0.24,
                                roughness: 0.75,
                            ),
                            // 2: heavily cratered iron-rich crust — dark
                            // oxidized iron-silicate, default catch-all.
                            (
                                name: "iron_crust",
                                albedo: 0.065,
                                fresh_albedo: Some(0.12),
                                tint: (1.08, 0.98, 0.90),
                                tonal_amp: 0.22,
                                roughness: 0.78,
                            ),
                        ],
                        rules: [
                            Fbm(frequency: 2.6, threshold: 0.22, octaves: 4),
                            Fbm(frequency: 1.8, threshold: 0.10, octaves: 4),
                            Default,
                        ],
                    )),
                    Cratering((
                        // Per-steradian density matches Mira (~22k craters/sr
                        // above ~3 texel widths). Max capped at 80 km —
                        // anything larger is basin-class and lives in the
                        // Megabasin stage.
                        total_count: 280000,
                        sfd_slope: 2.0,
                        sfd_slope_small: None,
                        sfd_break_radius_m: None,
                        min_radius_m: 1500.0,
                        max_radius_m: 80000.0,
                        age_bias: 1.0,
                        cubemap_bake_threshold_m: 1500.0,
                        secondary_parent_radius_m: 40000.0,
                        secondaries_per_parent: 18,
                    )),
                    // Smooth plains — Mercury-style effusive volcanic flood
                    // infill pooling in basin interiors. Not as dark as
                    // lunar mare (iron-rich crust is already dark), so the
                    // mare albedo sits only slightly above the iron_crust
                    // base. Wrinkle ridges on for that Mercurian character.
                    MareFlood((
                        target_count: 0,
                        additional_crater_count: 18,
                        fill_fraction: 0.60,
                        near_side_bias: 0.0,
                        boundary_noise_amplitude_m: 700.0,
                        boundary_noise_freq: 9.0,
                        episode_count: 2,
                        wrinkle_ridges: true,
                    )),
                    // Lobate thrust scarps — Mercury's hallmark feature,
                    // from >5 km global radius contraction as the iron core
                    // cooled. Tall, long, and more numerous than on any
                    // other body in the system.
                    Scarps((
                        count: 28,
                        min_length_m: 120000.0,
                        max_length_m: 420000.0,
                        width_m: 6000.0,
                        height_m: 1400.0,
                        curvature: 0.12,
                    )),
                    Regolith((
                        amplitude_m: 10.0,
                        characteristic_wavelength_m: 130.0,
                        crater_density_multiplier: 1.0,
                        bake_d_min_m: 600.0,
                        bake_scale: 1.0,
                        density_modulation: 0.25,
                        density_wavelength_m: 240000.0,
                    )),
                    SpaceWeather((
                        // Biomes drive highland color — no grayscale override.
                        mare_mature_albedo: 0.08,
                        mare_fresh_albedo: 0.13,
                        // Smooth plains weather slightly warmer than the
                        // heavily cratered iron crust.
                        mare_tint: (1.06, 1.00, 0.93),
                        young_crater_age_threshold: 0.9,
                        ray_age_threshold: 0.35,
                        ray_extent_radii: 8.0,
                        ray_count_per_crater: 12,
                        ray_half_width: 0.055,
                    )),
                ],
            )),
        ),
        (
            name: "Ashara",
            kind: Planet,
            parent: Some("Pyros"),
            physical: (
                mass_kg: 2.628e24,
                radius_m: 4035000.0,
                color: "#D1C774",
                albedo: 0.65,
                rotation_period_s: -15552000.0,
                axial_tilt_deg: 177.0,
            ),
            orbit: Some((
                semi_major_axis_m: 9.724e10,
                eccentricity: 0.01,
                inclination_deg: 2.8,
                lon_ascending_node_deg: 0.0,
                arg_periapsis_deg: 0.0,
                true_anomaly_deg: 192.0,
            )),
            generator: None,
        ),
        (
            name: "Thalos",
            kind: Planet,
            parent: Some("Pyros"),
            physical: (
                mass_kg: 1.378e24,
                radius_m: 3186000.0,
                color: "#3373E5",
                albedo: 0.35,
                rotation_period_s: 76680.0,
                axial_tilt_deg: 23.0,
            ),
            orbit: Some((
                semi_major_axis_m: 1.496e11,
                eccentricity: 0.017,
                inclination_deg: 0.0,
                lon_ascending_node_deg: 0.0,
                arg_periapsis_deg: 0.0,
                true_anomaly_deg: 0.0,
            )),
            // Thalos MVP tectonic recipe.
            //
            // Full roadmap in `docs/gen/thalos_processes.md`. This pipeline
            // implements Plates → Tectonics → Topography (MVP — no IQ
            // analytical-derivative noise yet) and drives Biomes from the
            // baked height field so land/ocean matches the plate geometry.
            //
            // Remaining stages (Hotspots, Hydrology, Climate, Biomes
            // expansion for rainforest/savannah/desert/rust signature)
            // ship after MVP signoff.
            generator: Some((
                seed: 1003,
                // Iron-core Earth analog: ~70% iron by volume, thin silicate
                // crust, residual volatiles as N₂/O₂ atmosphere + hydrosphere.
                // Matches `docs/solar_system.md` §III composition.
                composition: (silicate: 0.26, iron: 0.70, ice: 0.0, volatiles: 0.04, hydrogen_helium: 0.0),
                cubemap_resolution: 2048,
                body_age_gyr: 4.5,
                pipeline: [
                    Differentiate(()),
                    // Voronoi plate partition. 40 plates, 35% continental
                    // area (→ 65% ocean), clustered into ~4 seed groups to
                    // produce Earth-like loose-cluster continents rather
                    // than a checkerboard or a single supercontinent.
                    Plates((
                        n_plates: 40,
                        // Dropped from 0.35 → 0.30 together with the sea-
                        // level bump below. The pair produces more Earth-
                        // like continent separation (islands in a
                        // connected ocean) instead of the "big joined
                        // landmass" failure mode that 0.35 + 0.55 sea
                        // level was prone to.
                        continental_area_fraction: 0.30,
                        n_continental_seeds: 4,
                        neighbour_continental_bias: 0.5,
                        lloyd_iterations: 3,
                    )),
                    // Boundary classification. 20% active boundaries
                    // matches the "declining phase" narrative (most
                    // orogens old and worn; only a few still rising).
                    // This stage no longer writes orogen fields — that's
                    // OrogenDla's job; see below.
                    Tectonics((
                        active_boundary_fraction: 0.20,
                        orogen_age_peak_gyr: 2.0,
                    )),
                    // Diffusion-Limited Aggregation mountain ranges
                    // anchored to convergent boundaries. Replaces the
                    // old Voronoi-distance orogen field (which printed
                    // hexagonal cell outlines into the height map) with
                    // dendritic ridge networks grown from seeds planted
                    // along each convergent boundary.
                    OrogenDla((
                        // Level 7 → ~160k verts (~28 km spacing on
                        // Thalos) gives DLA enough resolution that
                        // dendritic branches fill in at mountain-ridge
                        // scale without individual stamps being visible
                        // as cells.
                        subdivision_level: 7,
                        seed_density: 6.0,
                        walkers_per_seed: 400,
                        walker_step_budget: 400,
                        launch_cap_km: 500.0,
                        // Stamp radius chosen slightly larger than the
                        // inter-sample spacing along an edge (edge ~28
                        // km / 8 samples ≈ 3.5 km), so stamps overlap
                        // into continuous ridges under quartic falloff.
                        ridge_falloff_km: 8.0,
                        depth_saturation: 5.0,
                        samples_per_edge: 8,
                        midpoint_jitter_frac: 0.4,
                    )),
                    // Height field: continentalness-lerped baseline
                    // + orogen bumps + fbm roughness + multi-scale
                    // regional fbm (warp-sampled) + coastal detail,
                    // renormalized so sea level sits at the target
                    // percentile of the distribution.
                    //
                    // Plate identity still decides where land *tends* to
                    // sit, but through a smooth weighted-blend of all
                    // plate kinds (`continentalness_bandwidth`-wide
                    // transitions at boundaries) — not a nearest-texel
                    // cubemap lookup. The lookup approach produced
                    // half-a-texel-wide discontinuities at cube-face
                    // seams that the shader's normal-gradient computation
                    // rendered as visible seam lines. Smooth blend keeps
                    // the height cubemap continuous.
                    //
                    // Regional fbm (±~4100 m total) overlaid on the
                    // baseline gap (±2000 m) lets cells flip across sea
                    // level near plate margins — inland seas and open-
                    // ocean islands emerge naturally. Peak active orogen
                    // budget 7 km (Thalos's 0.91 g gives near-Everest
                    // headroom). Ancient orogens decay via
                    // exp(-age / 1500 Myr) to rolling hills.
                    Topography((
                        // Baseline gap shrunk from (+500, −3500) to (+150,
                        // −1500) so the regional fbm field (±~4100 m
                        // total) dominates the land/ocean decision instead
                        // of the plate baselines. With the old gap the
                        // continental-vs-oceanic step printed plate
                        // shapes into the height field as visible
                        // pentagons; the smaller gap leaves continents to
                        // emerge from the noise + plate bias instead of
                        // from a hard step. Sea-level percentile (below)
                        // still hits the ~35% land target.
                        continental_baseline_m: 150.0,
                        oceanic_baseline_m: -1500.0,
                        // Gaussian-kernel `exp(−d²/bw²)` convention
                        // (changed when the previous exp-distance kernel
                        // was sprouting centroid spikes). bw = 0.12 ≈
                        // 28° ≈ 1600 km lets every cell receive
                        // meaningful weight from 2–3 neighbouring plates,
                        // so continentalness becomes a genuinely
                        // smooth low-frequency field rather than a
                        // per-plate plateau.
                        continentalness_bandwidth: 0.12,
                        peak_orogen_m: 7000.0,
                        // Uniform roughness — continentalness-gated
                        // amplitude would reintroduce a plate-kind step
                        // and re-create the seam problem.
                        roughness_m: 700.0,
                        orogen_age_scale_myr: 1500.0,
                        // 4.0 base × 7 octaves × 2.1 lacunarity puts the
                        // finest resolvable roughness at ~60 km features —
                        // mountain/hill scale, visible in the shader's
                        // height-gradient normal perturbation.
                        noise_frequency: 4.0,
                        // Three-level nested IQ-style domain warp
                        // (`f(p + s(p))` recursive). Inner perturbs mid's
                        // sample point; mid perturbs outer's; outer IS the
                        // warp applied to the plate-lookup direction.
                        // Nesting (not additive) gives multi-scale fractal
                        // coastlines: peninsulas at continent scale, bays
                        // inside, inlets inside those.
                        warp_amplitude: 0.16,
                        warp_frequency: 1.8,
                        warp_amplitude_mid: 0.10,
                        warp_frequency_mid: 5.0,
                        warp_amplitude_hi: 0.04,
                        warp_frequency_hi: 14.0,
                        // Multi-scale regional fbm: three independent bands
                        // composed additively. Lo picks where landmasses
                        // broadly sit; mid shapes subcontinents; hi fills
                        // in interior relief variation. Summed peaks reach
                        // ~4100 m — comparable to the baseline gap, so the
                        // combined field (not plate identity) decides
                        // where land sits.
                        regional_height_lo_m: 2000.0,
                        regional_frequency_lo: 0.5,
                        regional_height_m: 1500.0,
                        regional_frequency: 1.5,
                        regional_height_hi_m: 600.0,
                        regional_frequency_hi: 4.0,
                        // High-freq detail concentrated near sea level.
                        // Peaks at the coastline, decays within ±1300 m —
                        // producing fjord-like and archipelago-scatter
                        // roughness on shorelines without polluting
                        // mountain peaks or deep ocean. Widened from the
                        // initial ±800 m band so the fractal character
                        // reaches further inland (fjord-scale inlets) and
                        // further offshore (archipelago scatter).
                        // Amplitude kept smaller than the narrowest biome
                        // band it can cross (150 m coast) so speckle
                        // doesn't flip cells between coast and land/deep-
                        // ocean.
                        coastal_detail_m: 220.0,
                        coastal_detail_frequency: 18.0,
                        coastal_detail_scale_m: 1300.0,
                        // Renormalize so 65% of cells fall below sea level.
                        // Matches the design target in
                        // docs/gen/thalos_processes.md ("~65% ocean cover")
                        // and Earth's 71% for visual lineage. Higher ocean
                        // fraction also statistically separates continents
                        // more — a common Earth-like orbit-look pattern
                        // that 0.55 didn't reliably produce.
                        sea_level_percentile: 0.65,
                    )),
                    // Climate: annual-mean temperature and precipitation
                    // over the surface. Temperature is the latitude × lapse
                    // model; precipitation is zonal Hadley/Ferrel/polar
                    // bands plus wind advection (trade winds equatorward,
                    // westerlies mid-lat, polar easterlies) with
                    // continentality decay over land and orographic lift /
                    // rain shadow against mountain belts. Drives Biomes'
                    // Whittaker-style TempPrecip rules so the continent is
                    // partitioned into rainforest / savanna / desert /
                    // grassland / forest / taiga / tundra rather than a
                    // single rust-tinted "highland" tan.
                    Climate((
                        // Equator/pole annual means. Thalos is warmer than
                        // Earth at 1 AU because its 0.85 atm atmosphere is
                        // slightly less efficient at radiating, but the
                        // iron core heat flux is near-zero — pick a
                        // moderate Earth-like gradient.
                        equator_temp_c: 27.0,
                        polar_temp_c: -28.0,
                        // >1 widens the tropics and concentrates the drop
                        // near the poles; matches Earth's band widths.
                        lat_exponent: 1.3,
                        // Standard environmental lapse rate.
                        lapse_c_per_km: 6.5,
                        // Nine 10° bins, equator → pole. ITCZ wet, horse
                        // latitudes (20-30°) dry, Ferrel wet, subpolar
                        // medium, polar desert dry.
                        zonal_precip_mm: (2500.0, 2000.0, 600.0, 700.0, 1200.0, 1100.0, 800.0, 400.0, 200.0),
                        // 12 steps × 0.05 rad ≈ 0.60 rad ≈ 1900 km upwind
                        // trace on Thalos's 3186 km radius. Captures the
                        // dominant rain-shadow and continentality signal.
                        upwind_steps: 12,
                        step_arc_rad: 0.05,
                        // Each land step retains 90 % of moisture →
                        // 12 land steps retain 0.9^12 ≈ 0.28, producing
                        // clearly drier continental interiors without
                        // completely desiccating mid-continent.
                        continentality_decay: 0.90,
                        // Windward-slope boost and leeward rain-shadow.
                        // 0.5/km × 3 km rise ≈ 2.5× precip boost;
                        // 0.4/km × 3 km drop ≈ 2.2× divisor.
                        orographic_gain_per_km: 0.5,
                        rain_shadow_per_km: 0.4,
                        // Jitter breaks hard zonal bands into irregular
                        // blobs. 25 % wobble produces visibly chaotic
                        // precipitation patterns on top of the underlying
                        // latitudinal structure — matches Earth's mix of
                        // "Hadley cell gave this band the budget, but the
                        // actual rainfall is lumpy."
                        precip_noise_amp: 0.25,
                        precip_noise_frequency: 3.0,
                    )),
                    // Climate-driven biome palette. The previous elevation-
                    // only banding (highland/arid_lowland/lowland) painted
                    // most of the continent a single warm tan because
                    // Topography pushes the majority of land above 800 m;
                    // TempPrecip subdivides land by temperature × rainfall
                    // (Whittaker diagram) into realistic regional biomes.
                    //
                    // Rules are evaluated in order, first match wins. Ice /
                    // ocean / coast / alpine / orogen claim their cells
                    // first (these have hard physical definitions); the
                    // remaining land cells are then partitioned by climate.
                    // Iron-oxide rust tint is authored directly into
                    // hot_desert, cold_desert, and orogen_active — the
                    // "metal world signature" from docs/gen/thalos_processes.md.
                    Biomes((
                        biomes: [
                            (
                                // Deep ocean classifier. The *visible*
                                // ocean colour comes from PaintBiomes'
                                // ocean_depth overlay — this biome exists
                                // so the classifier has something to
                                // return below sea level and so roughness
                                // flows per-surface-type through the
                                // material palette.
                                name: "ocean",
                                albedo: 0.05,
                                fresh_albedo: Some(0.08),
                                tint: (0.30, 0.50, 1.00),
                                tonal_amp: 0.08,
                                roughness: 0.05,
                            ),
                            (
                                // Continental-shelf classifier. Same
                                // story — real colour comes from
                                // ocean_depth; tint kept close to the
                                // shallow-end target so any fallback
                                // stays in-family.
                                name: "coast",
                                albedo: 0.09,
                                fresh_albedo: Some(0.12),
                                tint: (0.55, 0.85, 1.00),
                                tonal_amp: 0.10,
                                roughness: 0.08,
                            ),
                            (
                                // Active tectonic uplift belts. Base tint
                                // slightly warm; the slope-driven
                                // rock_overlay paints bare rock on the
                                // steepest cells so the ridge reads
                                // independently of climate biome.
                                name: "orogen_active",
                                albedo: 0.18,
                                fresh_albedo: Some(0.26),
                                tint: (1.05, 0.92, 0.78),
                                tonal_amp: 0.20,
                                roughness: 0.92,
                            ),
                            (
                                // Equatorial wet — dense canopy. Muted
                                // olive from orbit, not the Crayola green
                                // the earlier tint printed as.
                                name: "rainforest",
                                albedo: 0.09,
                                fresh_albedo: Some(0.14),
                                tint: (0.65, 0.92, 0.62),
                                tonal_amp: 0.20,
                                roughness: 0.85,
                            ),
                            (
                                // Hot + dry — iron-rust Sahara analog.
                                // Red tint pulled back from 1.25→1.12 so
                                // it reads as warm tan, not neon orange.
                                name: "hot_desert",
                                albedo: 0.28,
                                fresh_albedo: Some(0.36),
                                tint: (1.12, 0.88, 0.62),
                                tonal_amp: 0.22,
                                roughness: 0.90,
                            ),
                            (
                                // Hot + moderate precip — golden savanna.
                                name: "savanna",
                                albedo: 0.20,
                                fresh_albedo: Some(0.28),
                                tint: (1.02, 0.95, 0.68),
                                tonal_amp: 0.24,
                                roughness: 0.80,
                            ),
                            (
                                // Temperate moist forest.
                                name: "temperate_forest",
                                albedo: 0.12,
                                fresh_albedo: Some(0.18),
                                tint: (0.78, 0.95, 0.66),
                                tonal_amp: 0.22,
                                roughness: 0.85,
                            ),
                            (
                                // Dry mid-latitudes + cold-zone steppe —
                                // muted rust/ochre.
                                name: "cold_desert",
                                albedo: 0.23,
                                fresh_albedo: Some(0.30),
                                tint: (1.08, 0.94, 0.72),
                                tonal_amp: 0.20,
                                roughness: 0.85,
                            ),
                            (
                                // Boreal coniferous forest.
                                name: "taiga",
                                albedo: 0.10,
                                fresh_albedo: Some(0.16),
                                tint: (0.72, 0.90, 0.75),
                                tonal_amp: 0.22,
                                roughness: 0.80,
                            ),
                            (
                                // Polar land — permafrost tundra. Snow
                                // overlay blends this base colour toward
                                // white as temperature drops; warm edge
                                // of the tundra reads as greyed earth,
                                // cold edge as fully snow-covered.
                                name: "tundra",
                                albedo: 0.22,
                                fresh_albedo: Some(0.30),
                                tint: (0.92, 0.94, 0.96),
                                tonal_amp: 0.12,
                                roughness: 0.70,
                            ),
                            (
                                // Default catch-all — temperate grassland.
                                name: "grassland",
                                albedo: 0.18,
                                fresh_albedo: Some(0.25),
                                tint: (0.98, 0.96, 0.72),
                                tonal_amp: 0.26,
                                roughness: 0.80,
                            ),
                        ],
                        rules: [
                            // Deep ocean and shelf — claim before climate
                            // rules so TempPrecip only sees land. Jitter
                            // softens shelf-edge and shoreline contours.
                            HeightBelow(m: -150.0, jitter_amp_m: 250.0, jitter_frequency: 3.5),
                            HeightBelow(m: 0.0, jitter_amp_m: 200.0, jitter_frequency: 4.0),
                            // Active mountain chains.
                            Orogen(min_intensity: 0.30, max_age_myr: Some(500.0), jitter_amp: 0.10, jitter_frequency: 4.0),
                            // ── Whittaker climate zones ───────────────
                            // Order: most-specific first.
                            // Tropical very wet → rainforest.
                            TempPrecip(
                                min_temp_c: 22.0,
                                min_precip_mm: 1700.0,
                                jitter_amp: 0.18,
                            ),
                            // Tropical dry → hot desert.
                            TempPrecip(
                                min_temp_c: 22.0,
                                max_precip_mm: 500.0,
                                jitter_amp: 0.18,
