                semi_major_axis_m: 4.99664e8,
                eccentricity: 0.0,
                inclination_deg: 1.2,
                lon_ascending_node_deg: 0.0,
                arg_periapsis_deg: 0.0,
                true_anomaly_deg: 72.0,
            )),
            // Ocean moon. 85% ocean cover, volcanic island arcs, no
            // continents proper. Tidal heating from Auron drives two
            // active margins and a handful of hotspot tracks — those
            // are the only things that reliably break the waterline.
            // Matches `docs/lore/solar_system.md`.
            generator: Some((
                seed: 1250,
                // Iron-rich core (8000 kg/m³ density) with residual
                // silicate mantle and thick hydrosphere + N₂/H₂O
                // atmosphere as the volatile budget.
                composition: (silicate: 0.20, iron: 0.70, ice: 0.05, volatiles: 0.05, hydrogen_helium: 0.0),
                cubemap_resolution: 1024,
                body_age_gyr: 4.5,
                pipeline: [
                    // Stage 1 — Tectonic Skeleton. Plate partition
                    // supplies the scaffold the active margins and
                    // hotspot tracks attach to. Pelagos has no
                    // continents, so the plates themselves don't read
                    // visually — their boundaries do, through tidal-
                    // heated arcs.
                    TectonicSkeleton((
                        // Level 7 ≈ 164 k vertices, ~20 km per hop on
                        // a 2350 km body. One level below Thalos —
                        // the island arcs read at ~100 km scales so
                        // 20 km resolution is adequate and keeps the
                        // pipeline fast while the rest of the body
                        // design settles.
                        subdivision_level: 7,
                        // 10 plates — small-world plate count. More
                        // than needed for tectonic drama, tuned so
                        // active-margin and hotspot placement has
                        // several distinct boundary tracks to pick
                        // from.
                        n_cratons: 10,
                        plate_warp_amplitude: 0.4,
                        plate_warp_frequency: 3.0,
                        plate_warp_octaves: 5,
                        // Two active margins — Pelagos is tidally
                        // heated by Auron, which drives more
                        // persistent active volcanism than a
                        // thermally-isolated body this size would
                        // have.
                        n_active_margins: 2,
                        // One rift scar for the sake of variety;
                        // doesn't read as a continental feature
                        // since there are no continents to rift.
                        n_rift_scars: 1,
                        // Six hotspot tracks — these ARE the visible
                        // island arc chains above water. More than
                        // Thalos because the arcs are the planet's
                        // whole above-water story.
                        n_hotspot_tracks: 6,
                        // 10 hops ≈ 200 km at level 7 — Hawaii-
                        // Emperor scale island chain. Each track
                        // contributes a few islands above water plus
                        // submerged seamount trail.
                        hotspot_track_length: 10,
                        lloyd_iterations: 3,
                        debug_paint_albedo: false,
                    )),
                    // Stage 2 — Coarse Elevation. Continental mask
                    // still comes from warped fBm thresholded at 15 %
                    // land, but the continental bias is tuned low so
                    // the "continents" read as shallow shelves with
                    // small island exposures rather than proper
                    // landmasses. Hotspots are tall enough (1500 m) to
                    // reliably pop above the waterline regardless of
                    // whether they land on the shelf or in open ocean.
                    CoarseElevation((
                        // 0.92 → ~8 % land. The spec's "85 % ocean"
                        // number produces ~30 % of the visible disk
                        // as land after hemisphere concentration,
                        // which reads as continents rather than
                        // "volcanic island arcs, no continents". 8 %
                        // global keeps a meaningful amount of land
                        // to form arcs without the continental read.
                        target_ocean_fraction: 0.92,
                        // Higher base frequency than Thalos (3.0 vs
                        // 2.0) — Thalos's 2.0 produces ~5 continent-
                        // scale patches, which on a body that's
                        // supposed to have no continents reads
                        // exactly wrong. 3.0 splits the land into
                        // roughly 10–15 smaller clusters, closer to
                        // archipelago scale.
                        continent_noise_frequency: 3.0,
                        continent_noise_octaves: 6,
                        continent_noise_persistence: 0.55,
                        continent_warp_amplitude: 0.45,
                        continent_warp_frequency: 2.2,
                        // Isotropic — no Earth-style E-W elongation
                        // bias. Ocean-world island clusters should
                        // read as blobs, not belts.
                        horizontal_stretch: 1.0,
                        // No latitude bias — tidal heating + ocean
                        // thermal inertia flattens the pole/equator
                        // gradient that drives Thalos's mid-lat
                        // preference.
                        mid_latitude_bias: 0.0,
                        // Keep small archipelagos (~0.05 % of sphere
                        // ≈ 35 000 km² ≈ Iceland-scale). Smaller than
                        // Thalos's 0.3 % filter because island arcs
                        // *are* the land.
                        min_land_fraction: 0.0005,
                        min_ocean_fraction: 0.0,
                        // Low shelf bias: +200 m on the continental
                        // side, −3000 m on oceanic. 200 m above
                        // sea level puts most of the "continental"
                        // surface as shallow shelf just above water,
                        // with noise-driven peaks rising as islands.
                        // Ocean floor at 3 km below sea level —
                        // shallower than Thalos's 3.5 km; spreading
                        // ridges on a tidally-heated moon would lift
                        // the average seafloor.
                        continental_bias_m: 200.0,
                        oceanic_bias_m: -3000.0,
                        // Modest suture relief — no major orogenies
                        // on a body with no sustained continent-
                        // continent collisions.
                        suture_height_m: 800.0,
                        suture_falloff_hops: 5.0,
                        suture_age_decay_myr: 800.0,
                        rift_depth_m: 600.0,
                        rift_falloff_hops: 3.0,
                        // Active margin: volcanic arc uplift + deep
                        // offshore trench. 2.5 km uplift → visible
                        // arc above water; 3 km trench sits 8 hops
                        // offshore.
                        active_uplift_m: 2500.0,
                        active_trench_m: 3000.0,
                        active_falloff_hops: 3.0,
                        trench_offset_hops: 8.0,
                        trench_width_hops: 3.0,
                        // 1500 m seamounts — with the +200 m
                        // continental bias or against the -3000 m
                        // ocean floor, a 1500 m bump plants a cone
                        // that reaches 1300 m ABOVE sea level on
                        // shelves and sits 1500 m below on deep
                        // ocean floor (seamounts). Tight falloff
                        // (1.5 hops) keeps them as isolated island
                        // points, not ridges.
                        hotspot_height_m: 1500.0,
                        hotspot_falloff_hops: 1.5,
                        // 1000 m noise — half the 2000 m gap
                        // between continental/oceanic bias, plenty
                        // of seafloor texture without pushing ocean
                        // noise above sea level.
                        noise_amplitude_m: 1000.0,
                        noise_frequency: 2.5,
                        noise_octaves: 7,
                        noise_persistence: 0.62,
                        warp_amplitude: 0.45,
                        warp_frequency: 3.0,
                        // Stage 3 repaints; leaving off to avoid
                        // wasted bake work.
                        debug_paint_albedo: false,
                    )),
                    // Stage 3 — Hydrological Carving. Fewer erosion
                    // iterations than Thalos: island arcs are small
                    // and young relative to continental cratons;
                    // there's not much topography to pound flat. The
                    // stage still runs to fix the sea level cleanly
                    // at the 85 % percentile and produce a drainage
                    // graph for the islands that do exist.
                    HydrologicalCarving((
                        erosion_iterations: 40,
                        erosion_k: 2.0e-4,
                        stream_power_m: 0.5,
                        stream_power_n: 1.0,
                        max_erosion_per_iter_m: 50.0,
                        deposition_rate: 0.08,
                        pit_fill_epsilon_m: 0.001,
                        target_ocean_fraction: 0.92,
                        // Islands have small catchments — drop the
                        // river threshold so any meaningful island
                        // drainage still shows up as a ribbon.
                        river_accumulation_threshold_m2: 5.0e10,
                        river_half_width_rad: 0.0008,
                        // No SurfaceMaterials stage yet — leave the
                        // hypsometric debug paint on so the final
                        // bake shows the sea level and bathymetry
                        // readably. Swap off once materials land.
                        debug_paint_albedo: true,
                    )),
                ],
            )),
            // N₂-dominant atmosphere at ~0.4 atm with CO₂/H₂O. Thinner
            // than Thalos's 0.85 atm, but lower gravity (0.54 g) lifts
            // the scale height — column height reads taller than a
            // naive pressure ratio would suggest. Clouds are a humid
            // ocean world's most distinctive read from orbit: high
            // coverage, fine-grained convective structure.
            terrestrial_atmosphere: Some((
                // Cool blue rim, slightly dimmer than Thalos's. N₂
                // Rayleigh still dominates the tint. Scale height
                // 10 km = Earth's 8.4 km × (0.4 atm / 0.85 atm) ÷
                // (0.54 g / 0.91 g) ≈ 10 km when the lower gravity
                // raises the column. Outer shell out to 120 km for
                // smoothed rim falloff.
                rim_halo: Some((
                    color: (0.45, 0.65, 0.95),
                    intensity: 0.18,
                    scale_height_m: 10000.0,
                    outer_altitude_m: 120000.0,
                )),
                limb: None,
                limb_darkening: None,
                // Rayleigh optical depth scales with column depth,
                // roughly 0.47 × Thalos at 0.4 atm / 0.85 atm. Produces
                // visibly softer sunsets and a paler blue haze than
                // Thalos — consistent with a thinner atmosphere.
                rayleigh: Some((
                    vertical_optical_depth: (0.022, 0.051, 0.124),
                    strength: 1.0,
                )),
                // Humid ocean moon. Coverage 0.30 — modestly wetter
                // than Thalos's 0.25, since 85 % ocean cover and tidal
                // heating sustain more evaporation and convection.
                // Raw Worley fBm peaks around 0.8 and the shader's
                // `cov_scale = 2·coverage` gate means much higher than
                // 0.30 pushes the disk into near-solid overcast.
                //
                // NOTE: `frequency`, `octaves`, `softness` have no
                // effect on the current render — the cloud cube is
                // baked with fixed Wedekind defaults (seed-only
                // variation), and the haze layer that would read
                // those fields is currently disabled in the shader.
                // They're kept for schema parity with Thalos / so
                // they're already populated when the haze layer and
                // per-body bake params return.
                clouds: Some((
                    coverage: 0.30,
                    softness: 0.18,
                    frequency: 3.5,
                    octaves: 10,
                    // Pale blue-cool cloud albedo. Slightly cooler
                    // than Thalos's off-white — thinner atmosphere
                    // gives less orange twilight reflection bias.
                    albedo: (0.78, 0.80, 0.84),
                    // Pelagos rotates every 6.2 days (~7× slower
                    // than Thalos); weather systems drift more
                    // slowly relative to the surface.
                    scroll_rate: 1.5e-5,
                    differential_rotation: 0.40,
                    seed: 7143,
                )),
            )),
