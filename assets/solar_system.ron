                    // adjacent jets read as a Saturn belt/zone pair.
                    // 0.05 = ±5% luminance — visible crisp edges that
                    // don't overpower the smooth hue gradient.
                    band_contrast: 0.05,
                    // No longer in use by the shader — kept for the
                    // serde schema. Edge crispness is now a hard step
                    // from the per-band luminance modulation.
                    band_sharpness: 0.0,
                    // No grey/cool tint multiplier — the palette
                    // carries all the chromatic information.
                    tint: (1.00, 1.00, 1.00),
                    // Saturn-style zonal wind profile: strong eastward
                    // equatorial superrotation flanked by alternating
                    // prograde/retrograde jets at mid latitudes, quiet
                    // poles. 16 stops so each jet at band_frequency=10
                    // gets its own signed speed and adjacent bands
                    // visibly counter-drift. Rate kept low so the noise
                    // field doesn't smear within a play session — a few
                    // minutes for clear differential motion, ~45 min
                    // before high-shear bands start to look ugly.
                    speed_profile: [
                         0.05, -0.15,  0.25, -0.20,
                         0.30, -0.25,  0.40,  0.85,
                         1.00,  0.45, -0.30,  0.35,
                        -0.25,  0.20, -0.15,  0.05,
                    ],
                    differential_rotation_rate: 0.0012,
                    // Gentle pole turbulence, quiet equator — the
                    // old 1.0-at-poles profile made the high-latitude
                    // cloud bands rip apart into blobs.
                    turbulence_profile: [
                        0.45, 0.40, 0.30, 0.22,
                        0.15,
                        0.22, 0.30, 0.40, 0.45,
                    ],
                    edge_wave_amp: 0.25,
                    curl_amp: 0.30,
                    // Two-layer parallax removed from shader; kept at
                    // zero for authoring-format compatibility.
                    parallax_amp: 0.0,
                    // No single large storm — the edge vortex chain
                    // now carries all the small eddies that populate
                    // the band boundaries.
                    named_vortices: [],
                    edge_vortex_chain: Some((
                        // Small angular radius = fine eddies
                        // compared to band width. With ~20 slots per
                        // band this gives a populated boundary
                        // without the eddies overlapping.
                        base_radius: 0.020,
                        strength: 0.9,
                        lifetime_s: 90.0,
                        slots_per_band: 20,
                    )),
                ),
                haze: Some((
                    tint: (0.78, 0.88, 0.92),
                    thickness: 0.10,
                    terminator_bias: 0.25,
                )),
                rim_halo: Some((
                    color: (0.62, 0.86, 0.96),
                    intensity: 0.35,
                    scale_height_m: 45000.0,
                    // Backlit-only shell. 180 km outer extent gives a
                    // thin Cassini-style crescent when the sun is
                    // behind Auron relative to the camera; lit-side
                    // external halo is no longer produced by the
                    // shader, so this value controls crescent width
                    // only.
                    outer_altitude_m: 180000.0,
                )),
                limb: Some((
                    terminator_warmth: (0.92, 0.78, 0.70),
                    terminator_strength: 0.35,
                    fresnel_color: (0.72, 0.88, 1.00),
                    // Stand-in for the spectral shift at Saturn's
                    // lit limb (upper-atmosphere Rayleigh dominant,
                    // not deep-cloud chromophore). 0.60 puts a clear
                    // cool tint on the edge without washing the
                    // palette — internal to the disk, no external
                    // glow.
                    fresnel_strength: 0.60,
                )),
                // Rayleigh blue-gap layer is disabled until a real
                // bake pipeline produces a high-frequency haze
                // density channel. The per-fragment fBm version
                // aliased into continent-sized blobs rather than the
                // narrow clearings Cassini shows, so the blue in
                // Auron's disk is now carried entirely by the
                // palette's polar stops.
                rayleigh: None,
                // Per-channel Minnaert limb darkening. Red darkens
                // slowest, blue fastest — reproduces the wavelength
                // trend in Cassini photometry. Strength 0.9 keeps
                // the effect strong but leaves a small floor so the
                // silhouette doesn't go pitch-black.
                limb_darkening: Some((
                    red:    0.22,
                    green:  0.30,
                    blue:   0.42,
                    strength: 0.90,
                )),
                // Saturn-style ring system. Inner edge roughly at
                // 1.25 R, outer at 2.3 R — matches Saturn's B/A
                // ring footprint. Cassini division lives around
                // r=0.42 of the radial span; the profile also
                // authors a dim C ring and a bright B ring core.
                rings: Some((
                    inner_radius_m:  55750000.0,
                    outer_radius_m: 102580000.0,
                    seed: 20101,
                    opacity: 1.00,
                    ringlet_noise: 0.55,
                    ringlet_octaves: 7,
                    palette: [
                        // Inner edge — translucent C-ring: dusky grey.
                        (r: 0.00, color: (0.32, 0.28, 0.24), opacity: 0.18),
                        (r: 0.18, color: (0.48, 0.42, 0.34), opacity: 0.40),
                        // Bright B-ring core — creamy gold.
                        (r: 0.30, color: (0.92, 0.82, 0.62), opacity: 0.95),
                        (r: 0.40, color: (1.00, 0.90, 0.68), opacity: 0.98),
                        // Cassini division — authored as a dark gap.
                        (r: 0.46, color: (0.18, 0.16, 0.14), opacity: 0.10),
                        // A-ring — warm tan.
                        (r: 0.55, color: (0.80, 0.68, 0.48), opacity: 0.82),
                        (r: 0.80, color: (0.74, 0.62, 0.44), opacity: 0.70),
                        // Outer edge — feathered F-ring stand-in.
                        (r: 1.00, color: (0.55, 0.48, 0.38), opacity: 0.25),
                    ],
